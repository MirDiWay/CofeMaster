<UserControl
    x:Class="CofeMaster.ViewingFolder.UserControlFolder.MenuButton_UserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:CofeMaster.ViewingFolder.UserControlFolder"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Style="{StaticResource MunuButton_UserControlStyle}"
    mc:Ignorable="d">
	<StackPanel Name="StackToggleButtonMenu_StackPanel">
		<ToggleButton
		    x:Name="Favorites_ToggleButton"
		    Click="MenuClick_ToggleButton"
		    Content="Избранное"
		    ToolTip="Избранное"
		    Visibility="Collapsed"/>
		<ToggleButton
		    x:Name="Range_ToggleButton"
		    Click="MenuClick_ToggleButton"
		    Content="Ассортимент"
		    ToolTip="Ассортимент"/>
		<ToggleButton
		    x:Name="Partners_ToggleButton"
		    Click="MenuClick_ToggleButton"
		    Content="Партнёры"
		    ToolTip="Партнёры"/>
		<ToggleButton
		    x:Name="Settings_ToggleButton"
		    Click="MenuClick_ToggleButton"
		    Content="Настройки"
		    ToolTip="Настройки"/>
	</StackPanel>
</UserControl>
<!--
	Решил отключить кнопку избранного, потому что
	мне не хватает времяни сделать эту штуку.
	Не думаю, что проект залетит как программа для
	общего пользования, и кто-то ей будет пользоваться
	и куда-то она пойдет, кроме как курсовой работы.
	Если эта программа пойдет в диплом или станет популярной
	то придется сделать эту функцию + сделать дизайн лучше
-->