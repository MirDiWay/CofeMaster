<UserControl
    x:Class="CofeMaster.ViewingFolder.UserControlFolder.RangeListView_UserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:CofeMaster.ViewingFolder.UserControlFolder"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="230"
    d:DesignWidth="270"
    mc:Ignorable="d">
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="170"/>
			<RowDefinition Height="60"/>
		</Grid.RowDefinitions>
		<Image
		    Grid.Row="0"
		    Width="224"
		    Height="126"
		    Source="{Binding ImagePathCoffee}"/>
		<TextBlock
		    Grid.Row="1"
		    HorizontalAlignment="Center"
		    FontSize="20"
		    Style="{StaticResource Data_TextBlockStyle}"
		    Text="{Binding NameCoffee}"/>
	</Grid>
</UserControl>
