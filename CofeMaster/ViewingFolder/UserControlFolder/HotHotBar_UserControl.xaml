<UserControl
    x:Class="CofeMaster.ViewingFolder.UserControlFolder.HotHotBar_UserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:CofeMaster.ViewingFolder.UserControlFolder"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Style="{StaticResource HotHotbar_UserControlStyle}"
    mc:Ignorable="d">
	<Border>
		<Grid>
			<StackPanel Style="{StaticResource ControlButton_StackPanelStyle}">
				<Button
				    Click="Minimize_Click"
				    Style="{StaticResource Rollup_HotHotbar_ButtonStyle}"/>
				<Button
				    Click="Close_Click"
				    Style="{StaticResource Close_HotHotbar_ButtonStyle}"/>
			</StackPanel>
			<Polygon
			    x:Name="PoligonName"
			    HorizontalAlignment="Center"
			    Fill="#44291e"
			    MouseLeftButtonDown="Polygon_MouseLeftButtonDown"
			    Opacity="1"
			    Points="0,0, 30,15, 650,15, 680,0"
			    ToolTip="Перемищать данное окно"/>
		</Grid>
	</Border>
</UserControl>
