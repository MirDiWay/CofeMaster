<Page
    x:Class="CofeMaster.ViewingFolder.PageFolder.Range_Page"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:control="clr-namespace:CofeMaster.ViewingFolder.UserControlFolder"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:CofeMaster.ViewingFolder.PageFolder"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Ассортимент"
    mc:Ignorable="d">
	<ListView
	    x:Name="Range_ListView"
	    ItemContainerStyle="{StaticResource ListViewItemSelected}">
		<ListView.ItemsPanel>
			<ItemsPanelTemplate>
				<WrapPanel
				    HorizontalAlignment="Center"
				    VerticalAlignment="Center"
				    Background="Transparent"
				    IsItemsHost="True"/>
			</ItemsPanelTemplate>
		</ListView.ItemsPanel>
		<ListView.ItemTemplate>
			<DataTemplate>
				<control:RangeListView_UserControl/>
			</DataTemplate>
		</ListView.ItemTemplate>
	</ListView>
</Page>
