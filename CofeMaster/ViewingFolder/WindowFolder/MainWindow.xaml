<Window
    x:Class="CofeMaster.ViewingFolder.WindowFolder.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:control="clr-namespace:CofeMaster.ViewingFolder.UserControlFolder"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:CofeMaster.ViewingFolder.WindowFolder"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="{Binding ElementName=BodyFrame, Path=Content.Title}"
    Style="{StaticResource Basic_WindowStyle}"
    mc:Ignorable="d">
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="40"/>
			<RowDefinition/>
		</Grid.RowDefinitions>
		<Border
		    Grid.Row="0"
		    Style="{StaticResource HotHotbar_BorderStyle}">
			<control:HotHotBar_UserControl/>
		</Border>
		<Border
		    Grid.Row="1"
		    Style="{StaticResource MainBorder_BorderStyle}">
			<Frame x:Name="MainFrame"/>
		</Border>
	</Grid>
</Window>
