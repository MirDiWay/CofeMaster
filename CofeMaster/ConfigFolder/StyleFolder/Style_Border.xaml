<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<Style
	    x:Key="HotHotbar_BorderStyle"
	    TargetType="Border">
		<Setter Property="Background" Value="#1d0f0c"/>
		<Setter Property="BorderBrush" Value="#1d0f0c"/>
		<Setter Property="BorderThickness" Value="0"/>
		<Setter Property="CornerRadius" Value="0"/>
		<!--<Setter Property="VerticalAlignment" Value="Center"/>
		<Setter Property="HorizontalAlignment" Value="Center"/>-->
		<Setter Property="FocusVisualStyle" Value="{x:Null}"/>
	</Style>
	<Style
	    x:Key="MainBorder_BorderStyle"
	    BasedOn="{StaticResource HotHotbar_BorderStyle}"
	    TargetType="Border">
		<Setter Property="Background" Value="#44291e"/>
	</Style>
	<Style
	    x:Key="MenuButtonBorder_BorderStyle"
	    BasedOn="{StaticResource HotHotbar_BorderStyle}"
	    TargetType="Border">
		<Setter Property="Background" Value="#1d0f0c"/>
	</Style>
	<Style
	    x:Key="NeonBorder"
	    TargetType="Border">
		<Setter Property="Background" Value="Transparent"/>
		<Setter Property="BorderBrush" Value="#f5f5f5"/>
		<Setter Property="BorderThickness" Value="2"/>
		<Setter Property="CornerRadius" Value="10"/>
		<Setter Property="Margin" Value="0"/>
		<Setter Property="FocusVisualStyle" Value="{x:Null}"/>
	</Style>
</ResourceDictionary>