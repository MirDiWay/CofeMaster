<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<Style
	    x:Key="Icon_TextBlockStyle"
	    TargetType="TextBlock">
		<Setter Property="FocusVisualStyle" Value="{x:Null}"/>
		<Setter Property="Foreground" Value="#F8F8F0"/>
		<Setter Property="FontFamily" Value="\ConfigFolder\ContentFolder\FontFolder\#Material-Design-Iconic-Font"/>
		<Setter Property="FontSize" Value="20"/>
		<Setter Property="VerticalAlignment" Value="Center"/>
		<Setter Property="HorizontalAlignment" Value="Left"/>
		<Setter Property="IsHitTestVisible" Value="False"/>
		<Setter Property="Margin" Value="10,0,0,0"/>
	</Style>
	<Style
	    x:Key="TitleWindow_TextBlockStyle"
	    TargetType="TextBlock">
		<Setter Property="FocusVisualStyle" Value="{x:Null}"/>
		<Setter Property="Foreground" Value="#F8F8F0"/>
		<Setter Property="FontFamily" Value="Consolas"/>
		<Setter Property="FontSize" Value="20"/>
		<Setter Property="VerticalAlignment" Value="Center"/>
		<Setter Property="HorizontalAlignment" Value="Left"/>
		<Setter Property="IsHitTestVisible" Value="False"/>
	</Style>
	<Style
	    x:Key="Description_TextBlockStyle"
	    TargetType="TextBlock">
		<Setter Property="FocusVisualStyle" Value="{x:Null}"/>
		<Setter Property="Foreground" Value="#F8F8F0"/>
		<Setter Property="FontFamily" Value="Consolas"/>
		<Setter Property="FontSize" Value="20"/>
		<Setter Property="VerticalAlignment" Value="Center"/>
		<Setter Property="HorizontalAlignment" Value="Left"/>
		<Setter Property="IsHitTestVisible" Value="False"/>
		<Setter Property="TextWrapping" Value="Wrap"/>
	</Style>
	<Style
	    x:Key="One_TextBlockStyle"
	    TargetType="TextBlock">
		<Setter Property="FocusVisualStyle" Value="{x:Null}"/>
		<Setter Property="Foreground" Value="#a76b49"/>
		<Setter Property="FontFamily" Value="Consolas"/>
		<Setter Property="FontSize" Value="20"/>
		<Setter Property="VerticalAlignment" Value="Center"/>
		<Setter Property="HorizontalAlignment" Value="Left"/>
		<Setter Property="IsHitTestVisible" Value="False"/>
		<Setter Property="TextWrapping" Value="Wrap"/>
	</Style>
	<Style
	    x:Key="Data_TextBlockStyle"
	    TargetType="TextBlock">
		<Setter Property="FocusVisualStyle" Value="{x:Null}"/>
		<Setter Property="Foreground" Value="#e3af87"/>
		<Setter Property="FontFamily" Value="Consolas"/>
		<Setter Property="FontSize" Value="20"/>
		<Setter Property="VerticalAlignment" Value="Center"/>
		<Setter Property="HorizontalAlignment" Value="Left"/>
		<Setter Property="IsHitTestVisible" Value="False"/>
		<Setter Property="TextWrapping" Value="Wrap"/>
	</Style>
</ResourceDictionary>